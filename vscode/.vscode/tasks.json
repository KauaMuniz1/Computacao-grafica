{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build active cpp (OpenGL)",
      "type": "shell",
      "command": "g++",
      "args": [
        "-g",
        "${file}",
        "-o",
        "${fileDirname}/${fileBasenameNoExtension}",
        "-lGL",
        "-lGLU",
        "-lglut"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gcc"
      ],
      "detail": "Compila o arquivo C++ ativo com OpenGL/GLUT"
    }
  ]
}
